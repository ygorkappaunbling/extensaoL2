{
	"name": "Controle de tickets",
	"version": "1.0",
	"manifest_version": 3,
	"description": "Extensão para registro detalhado de tickets",
	"action": {
		"default_popup": "index.html",
		"default_title": "Controle de tickets"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"permissions": [
		"tabs", "identity", "identity.email", "storage", "scripting"
	],
	"host_permissions": ["https://*.bling.com.br/suporte.php*"],
	"background": {
		"service_worker": "scripts/background.js"
	},
"key": "",
"oauth2": {
	"client_id": "791760818029-be26rb8h5v0tdl9amho71u5d61h37mlo.apps.googleusercontent.com",
	"scopes": [
		"https://www.googleapis.com/auth/spreadsheets"
	]
},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"web_accessible_resources": [
		{
			"resources": [
				"data/*.json"
			],
			"matches": [
				"*://*/*"
			]
		}
	]
}
